# Base URL of the event-admin backend (the ONLY backend this SPA talks to;
# event-admin proxies /api/users/* to event-users itself).
# Leave empty only when the SPA is served from the same origin as event-admin:
# requests then become relative and, in dev, the Vite proxy forwards
# /auth, /bookings, /api and /health to this URL (default http://localhost:8000).
VITE_API_BASE_URL=http://localhost:8000

# Dev-only login bypass. The button is rendered only in `npm run dev` builds
# (import.meta.env.DEV) AND when both variables below are set.
VITE_ENABLE_DEV_BYPASS_LOGIN=false

# JWT used when the dev bypass button is clicked. Mint it with the event-admin
# JWT secret; the role claim must be "admin" (the backend rejects everything else).
VITE_DEV_BYPASS_JWT=
